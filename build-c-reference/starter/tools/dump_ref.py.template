# ===========================================================================
#   PyTorch / HF backend — forward_hook based
# ===========================================================================

def run_pytorch(args, layers):
    tok = AutoTokenizer.from_pretrained(args.model, trust_remote_code=True)
    # Use AutoModel (with trust_remote_code=True for non-mainline architectures
    # like discrete-diffusion LMs); fall back to AutoModelForCausalLM otherwise.
    model = AutoModelForCausalLM.from_pretrained(
        args.model, torch_dtype=torch.bfloat16, device_map="cpu",
        trust_remote_code=True)
    model.eval()
    messages = [
        {"role": "system", "content": args.system or "You are a helpful assistant."},
        {"role": "user",   "content": args.user},
    ]
    ids = tok.apply_chat_template(messages, add_generation_prompt=True,
                                  return_tensors="pt")
    save_bin(f"{args.out}/input_ids.bin", ids[0].numpy(), "i32")

    captures = {}
    def hook(name):
        def f(_mod, _inp, out):
            # Attention layers may return a (output, weights, past_kv) tuple;
            # most other modules return a plain Tensor.
            arr = (out[0] if isinstance(out, tuple) else out).detach().float().cpu().numpy()
            captures[name] = arr
        return f

    for li in layers:
        layer = model.model.layers[li]
        layer.input_layernorm.register_forward_hook(hook(f"x_after_rmsnorm_{li}"))
        layer.self_attn.q_proj.register_forward_hook(hook(f"q_proj_{li}"))
        layer.self_attn.k_proj.register_forward_hook(hook(f"k_proj_{li}"))
        layer.self_attn.v_proj.register_forward_hook(hook(f"v_proj_{li}"))
        # [MODEL] add more hooks: o_proj, router, gate_up, swiglu, down, etc.

    # IMPORTANT: PyTorch CPU's default SDPA backend for bf16 is
    # FLASH_ATTENTION, which disagrees with the textbook math by
    # mean|d|~0.004 / max|d|~0.9. Force MATH so the dumped oracle
    # matches what a naive C SDPA kernel computes.
    from torch.nn.attention import SDPBackend, sdpa_kernel
    with torch.inference_mode(), sdpa_kernel([SDPBackend.MATH]):
        out = model.generate(ids, max_new_tokens=1, do_sample=False)
    save_bin(f"{args.out}/next_id.bin",
             np.array([out[0, ids.shape[1]].item()], dtype=np.int32), "i32")
    for k, v in captures.items():
        save_bin(f"{args.out}/{k}.bin", v, "f32")
    return 0


if __name__ == "__main__":
    sys.exit(main())
