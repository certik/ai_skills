#!/usr/bin/env python3
"""dump_ref.py.template — run the Python reference model on a fixed prompt
and dump per-op intermediate tensors as f32 binaries readable by the C
per-kernel correctness tests.

Two backends are supported:
  - **PyTorch / HF transformers**: use `forward_hook`s to capture module
    outputs (simple, no code duplication).
  - **MLX**: MLX modules have NO `forward_hook` mechanism. You must
    manually walk the forward pass in Python, mirroring the reference's
    layer code, and call `save_bin(...)` at every op boundary you want to
    validate. See the worked example below.

Output layout (in --out dir, default src-cpu/refs/):
    input_ids.bin                    int32  [L]
    x_after_embed.bin                f32    [L, hidden]
    x_after_rmsnorm_<i>.bin          f32    [L, hidden]
    q_proj_<i>.bin                   f32    [L, n_qheads*head_dim]
    ...
    logits.bin                       f32    [vocab]
    next_id.bin                      int32  [1]

Binary format (matches loader in tests/load_ref.h):
    magic    : "LLMTNSR1"                  (8 bytes)
    u32      : dtype code (0=f32, 1=i32)
    u32      : ndim
    i64[ndim]: shape
    data     : ndim * elem_size * Π(shape) bytes, little-endian
"""
from __future__ import annotations
import argparse
import json
import os
import struct
import sys

import numpy as np

# [MODEL] Choose ONE backend.
USE_MLX = True
if USE_MLX:
    import mlx.core as mx
    import mlx.nn as nn
    from mlx_lm import load
else:
    import torch
    from transformers import AutoModelForCausalLM, AutoTokenizer


MAGIC = b"LLMTNSR1"
DT_F32, DT_I32 = 0, 1


def save_bin(path: str, arr, dtype: str) -> None:
    if dtype == "f32":
        a = np.array(arr, dtype=np.float32, copy=False)
        code = DT_F32
    elif dtype == "i32":
        a = np.array(arr, dtype=np.int32, copy=False)
        code = DT_I32
    else:
        raise ValueError(dtype)
    with open(path, "wb") as f:
        f.write(MAGIC)
        f.write(struct.pack("<II", code, a.ndim))
        for s in a.shape:
            f.write(struct.pack("<q", int(s)))
        f.write(a.tobytes())
    print(f"  wrote {path}: dtype={dtype} shape={list(a.shape)}")


def to_np_f32_mlx(a):  # MLX: eval + cast
    mx.eval(a)
    return np.array(a.astype(mx.float32))


def main() -> int:
    p = argparse.ArgumentParser()
    p.add_argument("--model", required=True, help="HF model dir")
    p.add_argument("--out", default="src-cpu/refs")
    p.add_argument("--system", default=None,
                   help="optional system message (omit for Qwen-style chat)")
    p.add_argument("--user", default="Hello, who are you?")
    p.add_argument("--layers", default="0",
                   help="comma-separated layer indices to dump (default 0)")
    args = p.parse_args()

    os.makedirs(args.out, exist_ok=True)
    layers = sorted({int(x) for x in args.layers.split(",")})

    if USE_MLX:
        return run_mlx(args, layers)
    else:
        return run_pytorch(args, layers)


# ===========================================================================
#   MLX backend — manual forward-pass walk
# ===========================================================================

