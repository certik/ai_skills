// main.c.template — pure-C CPU reference CLI for an LLM.
//
// Customize the parts marked [MODEL]: weight array (tensor) names, the
// forward() schedule (which kernels in which order), the chat-template
// builder, and the config fields you load from config.json.
//
// Build: see Makefile.template.
//
// Usage:
//   ./<BIN> --prompt "Hello, who are you?" --max-tokens 16
//   ./<BIN> --prompt "..." --system "You are a pirate." --model PATH

#include "kernels.h"
#include "safetensors.h"
#include "tokenizer.h"
#include "<chattmpl>.h"     // [MODEL] chat-template builder (e.g., harmony.h)
#include "utils/json.h"

#include <math.h>
#include <stdint.h>
#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include <time.h>

// ---- [MODEL] config struct, populated from config.json --------------------
typedef struct {
    int n_layers;
    int hidden;
    int n_qheads;
    int n_kvheads;
    int head_dim;
    int inter;
    int n_experts;
    int k_top;
    int vocab;
    int window;
    int max_ctx;        // hardcoded for now; set conservatively
    float rms_eps;
    float swiglu_alpha;
    float swiglu_limit;
} cfg_t;

static void load_config(const char* model_dir, cfg_t* c) {
    char path[1024];
    snprintf(path, sizeof(path), "%s/config.json", model_dir);

    char* err = NULL;
    json_doc_t* doc = json_open_file(path, &err);
    if (!doc) { fprintf(stderr, "config: %s\n", err); exit(1); }
    json_val_t root = json_root(doc);

    // [MODEL] Multi-modal wrappers nest the LM dims inside `text_config`.
    // For text-only models pass `root` instead.
    json_val_t lm = json_get(root, "text_config");
    if (json_is_null(lm)) lm = root;

    // [MODEL] Adjust key names + defaults to match your config.json schema.
    c->n_layers   = (int)json_int_or(json_get(lm, "num_hidden_layers"), 32);
    c->hidden     = (int)json_int_or(json_get(lm, "hidden_size"), 4096);
    c->n_qheads   = (int)json_int_or(json_get(lm, "num_attention_heads"), 32);
    c->n_kvheads  = (int)json_int_or(json_get(lm, "num_key_value_heads"), 8);
    c->head_dim   = (int)json_int_or(json_get(lm, "head_dim"), c->hidden / c->n_qheads);
    c->inter      = (int)json_int_or(json_get(lm, "intermediate_size"), 14336);
    c->n_experts  = (int)json_int_or(json_get(lm, "num_local_experts"), 0);
    c->k_top      = (int)json_int_or(json_get(lm, "num_experts_per_tok"), 0);
    c->vocab      = (int)json_int_or(json_get(lm, "vocab_size"), 128256);
    c->window     = (int)json_int_or(json_get(lm, "sliding_window"), 0);
    c->rms_eps    = (float)json_double_or(json_get(lm, "rms_norm_eps"), 1e-5);
    c->swiglu_alpha = 1.702f;          // [MODEL] gpt-oss-style
    c->swiglu_limit = 7.0f;            // [MODEL] gpt-oss-style
    c->max_ctx    = 1024;

    json_close(doc);
}

// ---- Globals: weights archive, tokenizer, workspace -----------------------
static st_archive* g_arch;
static cfg_t g_cfg;

// Per-layer KV caches.
static bf16** g_k_cache;  // [n_layers][max_ctx * n_kvheads * head_dim]
static bf16** g_v_cache;

// Workspace buffers, sized for worst-case Lq = max_ctx.
static bf16 *x_buf, *h_buf, *q_buf, *attn_buf, *o_buf;
static bf16 *router_buf, *mid_buf, *down_buf, *mlp_buf;
static int32_t *tk_idx_buf;
static float   *tk_w_buf;
static bf16    *logits_buf;

static void* tensor_ptr(const char* name, size_t* nbytes) {
    const st_tensor* t = st_find(g_arch, name);
    if (!t) { fprintf(stderr, "missing tensor: %s\n", name); exit(1); }
    if (nbytes) *nbytes = t->nbytes;
    return t->data;
}

// ---- forward() ------------------------------------------------------------
// [MODEL] customize this for your model. Call the kernels in the SAME order
// the reference's forward() calls its ops.
static void forward(int q_off, int Lq) {
    char nm[256];
    int Lk = q_off + Lq;
    (void)Lk;

    // Example structure (gpt-oss-shaped) — replace per your model:
    for (int li = 0; li < g_cfg.n_layers; li++) {
        // rmsnorm(in)
        snprintf(nm, sizeof(nm), "model.layers.%d.input_layernorm.weight", li);
        rmsnorm_bf16(x_buf, (const bf16*)tensor_ptr(nm, NULL), h_buf,
                     (uint32_t)Lq, (uint32_t)g_cfg.hidden, g_cfg.rms_eps);

        // q_proj, k_proj, v_proj
        snprintf(nm, sizeof(nm), "model.layers.%d.self_attn.q_proj.weight", li);
        const bf16* Wq = tensor_ptr(nm, NULL);
        snprintf(nm, sizeof(nm), "model.layers.%d.self_attn.q_proj.bias", li);
        const bf16* Bq = tensor_ptr(nm, NULL);
        linear_bf16(h_buf, Wq, Bq, q_buf,
                    (uint32_t)Lq, (uint32_t)g_cfg.hidden,
                    (uint32_t)(g_cfg.n_qheads * g_cfg.head_dim));

        // ... k_proj into k_cache[li] at q_off, v_proj into v_cache[li] at q_off
        // ... rope(q), rope(k)
        // ... sdpa(q, k_cache[li][0..Lk], v_cache[li][0..Lk]) -> attn_buf
        // ... o_proj(attn_buf) -> o_buf
        // ... residual_add(x_buf, o_buf)
        // ... rmsnorm(post)
        // ... router_linear, topk_softmax
        // ... mxfp4_linear_gather(h, gate_up_W) -> gate_up
        // ... swiglu(gate, up) -> mid
        // ... mxfp4_linear_gather(mid, down_W) -> down
        // ... expert_mix(down, tk_w) -> mlp_buf
        // ... residual_add(x_buf, mlp_buf)
    }

    // final rmsnorm + lm_head
    rmsnorm_bf16(x_buf + (size_t)(Lq - 1) * g_cfg.hidden,
                 (const bf16*)tensor_ptr("model.norm.weight", NULL),
                 h_buf, 1, (uint32_t)g_cfg.hidden, g_cfg.rms_eps);
    linear_bf16(h_buf, (const bf16*)tensor_ptr("lm_head.weight", NULL),
                NULL, logits_buf, 1, (uint32_t)g_cfg.hidden,
                (uint32_t)g_cfg.vocab);
}

// ---- main -----------------------------------------------------------------
int main(int argc, char** argv) {
    const char* prompt    = NULL;
    const char* sysmsg    = "You are a helpful assistant.";
    const char* model_dir = NULL;
    int max_tokens = 16;
    // [MODEL] Add model-specific args here (e.g., --reasoning for gpt-oss).
    const char* chattmpl_extra = NULL;

    for (int i = 1; i < argc; i++) {
        if      (!strcmp(argv[i],"--prompt")     && i+1<argc) prompt    = argv[++i];
        else if (!strcmp(argv[i],"--system")     && i+1<argc) sysmsg    = argv[++i];
        else if (!strcmp(argv[i],"--model")      && i+1<argc) model_dir = argv[++i];
        else if (!strcmp(argv[i],"--max-tokens") && i+1<argc) max_tokens = atoi(argv[++i]);
        // [MODEL] e.g., --reasoning low|medium|high for gpt-oss harmony
        else if (!strcmp(argv[i],"--chat-extra") && i+1<argc) chattmpl_extra = argv[++i];
        else { fprintf(stderr, "unknown arg: %s\n", argv[i]); return 2; }
    }
    if (!prompt || !model_dir) {
        fprintf(stderr,
            "usage: %s --prompt TEXT --model PATH [--system TEXT]"
            " [--max-tokens N] [--chat-extra TEXT]\n", argv[0]);
        return 2;
    }

    // ---- Load tokenizer + build prompt ----
    char* err = NULL;
    tokenizer_t* tk = tk_load("src-cpu/tokenizer.bin", &err);
    if (!tk) { fprintf(stderr, "tokenizer load: %s\n", err); return 1; }
    int prompt_ids[1024];
    // [MODEL] adjust to your chat-template builder's signature.  The example
    // below passes a chattmpl_extra string; for gpt-oss this is the reasoning
    // level ("low"/"medium"/"high"); for llama3 it might be unused.
    int Lp = <chattmpl>_build_prompt(tk, sysmsg, prompt, chattmpl_extra,
                                     prompt_ids, 1024);
    if (Lp < 0) { fprintf(stderr, "prompt too long\n"); return 1; }

    // ---- Load weights + config ----
    load_config(model_dir, &g_cfg);
    fprintf(stderr,
        "config: n_layers=%d hidden=%d n_qheads=%d n_kvheads=%d head_dim=%d "
        "inter=%d n_experts=%d k_top=%d vocab=%d window=%d\n",
        g_cfg.n_layers, g_cfg.hidden, g_cfg.n_qheads, g_cfg.n_kvheads,
        g_cfg.head_dim, g_cfg.inter, g_cfg.n_experts, g_cfg.k_top,
        g_cfg.vocab, g_cfg.window);

    fprintf(stderr, "loading weights from %s ...\n", model_dir);
    g_arch = st_open(model_dir, &err);
    if (!g_arch) { fprintf(stderr, "weights: %s\n", err); return 1; }

    // ---- Allocate KV caches + workspace ----
    g_k_cache = calloc((size_t)g_cfg.n_layers, sizeof(bf16*));
    g_v_cache = calloc((size_t)g_cfg.n_layers, sizeof(bf16*));
    size_t kv_per = (size_t)g_cfg.max_ctx * g_cfg.n_kvheads * g_cfg.head_dim;
    for (int li = 0; li < g_cfg.n_layers; li++) {
        g_k_cache[li] = calloc(kv_per, sizeof(bf16));
        g_v_cache[li] = calloc(kv_per, sizeof(bf16));
    }
    size_t cap = (size_t)g_cfg.max_ctx;
    x_buf      = calloc(cap * g_cfg.hidden, sizeof(bf16));
    h_buf      = calloc(cap * g_cfg.hidden, sizeof(bf16));
    q_buf      = calloc(cap * g_cfg.n_qheads * g_cfg.head_dim, sizeof(bf16));
    attn_buf   = calloc(cap * g_cfg.n_qheads * g_cfg.head_dim, sizeof(bf16));
    o_buf      = calloc(cap * g_cfg.hidden, sizeof(bf16));
    router_buf = calloc(cap * g_cfg.n_experts, sizeof(bf16));
    mid_buf    = calloc(cap * g_cfg.k_top * g_cfg.inter, sizeof(bf16));
    down_buf   = calloc(cap * g_cfg.k_top * g_cfg.hidden, sizeof(bf16));
    mlp_buf    = calloc(cap * g_cfg.hidden, sizeof(bf16));
    tk_idx_buf = calloc(cap * g_cfg.k_top, sizeof(int32_t));
    tk_w_buf   = calloc(cap * g_cfg.k_top, sizeof(float));
    logits_buf = calloc((size_t)g_cfg.vocab, sizeof(bf16));

    // ---- Prefill ----
    embed_gather_bf16(prompt_ids,
                      (const bf16*)tensor_ptr("model.embed_tokens.weight", NULL),
                      x_buf, (uint32_t)Lp, (uint32_t)g_cfg.hidden);
    struct timespec t0, t1;
    clock_gettime(CLOCK_MONOTONIC, &t0);
    forward(0, Lp);
    int32_t next_id;
    argmax_bf16(logits_buf, &next_id, (uint32_t)g_cfg.vocab);
    clock_gettime(CLOCK_MONOTONIC, &t1);
    double sec_pf = (t1.tv_sec - t0.tv_sec) + (t1.tv_nsec - t0.tv_nsec) * 1e-9;

    // ---- Decode loop ----
    // For byte-level BPE tokenizers (Qwen, Llama 3, GPT-2 family, ...),
    // each token's stored bytes are already the UTF-8 fragment to emit.
    // Concatenating fragments produces valid UTF-8 even across multi-byte
    // character boundaries, so we can safely `fwrite` each token's bytes
    // as soon as they're produced. We also buffer the full text for a
    // final summary print at the end.
    int stop_id = tk_special(tk, "<|return|>");   // [MODEL] adjust
    int n_gen = 0;
    size_t out_cap = 4096, out_len = 0;
    char*  out_buf = (char*)malloc(out_cap);
    clock_gettime(CLOCK_MONOTONIC, &t0);
    while (n_gen < max_tokens) {
        n_gen++;
        if (next_id == stop_id) break;
        int blen = 0;
        const char* bytes = tk_token_bytes(tk, next_id, &blen);
        if (bytes && blen > 0) {
            fwrite(bytes, 1, (size_t)blen, stdout);
            fflush(stdout);
            if (out_len + (size_t)blen + 1 > out_cap) {
                while (out_len + (size_t)blen + 1 > out_cap) out_cap *= 2;
                out_buf = (char*)realloc(out_buf, out_cap);
            }
            memcpy(out_buf + out_len, bytes, (size_t)blen);
            out_len += (size_t)blen;
        }

        embed_gather_bf16(&next_id,
                          (const bf16*)tensor_ptr("model.embed_tokens.weight", NULL),
                          x_buf, 1, (uint32_t)g_cfg.hidden);
        forward(Lp + n_gen - 1, 1);
        argmax_bf16(logits_buf, &next_id, (uint32_t)g_cfg.vocab);
    }
    fputc('\n', stdout);
    clock_gettime(CLOCK_MONOTONIC, &t1);
    double sec_dec = (t1.tv_sec - t0.tv_sec) + (t1.tv_nsec - t0.tv_nsec) * 1e-9;

    out_buf[out_len] = '\0';
    fprintf(stderr,
        "\n----- generated -----\n%s\n"
        "[stats] prompt=%d tokens, generated=%d tokens\n"
        "        prefill: %.2f s (%.1f tok/s)\n"
        "        decode:  %.2f s (%.1f tok/s)\n",
        out_buf, Lp, n_gen, sec_pf, Lp/sec_pf, sec_dec, n_gen/sec_dec);
    free(out_buf);

    tk_free(tk);
    return 0;
}
