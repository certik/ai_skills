# Makefile.template — pure-C CPU reference build.
#
# Replace <BIN> with the binary name you want. Choose a model-specific name (e.g., `llama3-cpu`, `qwen2-cpu`) or a generic one (e.g., `llm-cpu`, `infer-cpu`).
# Drop into the repo root; it expects sources in `src-cpu/`.

CC      ?= clang
CFLAGS  := -std=c99 -O2 -Wall -Wextra -Wno-unused-parameter -Wno-unused-function -Isrc-cpu

BIN     := <BIN>

# Add new kernel .c files as you author them.  Per-kernel correctness
# tests live in `tests/` and are built by the `tests` target.
SRCS    := src-cpu/main.c \
           src-cpu/kernels.c \
           src-cpu/safetensors.c \
           src-cpu/tokenizer.c \
           src-cpu/<chattmpl>.c

OBJS    := $(SRCS:.c=.o)

# Per-kernel correctness tests.  Add one entry per `tests/test_<kernel>.c`.
TEST_BINS := tests/test_rmsnorm tests/test_linear

.PHONY: all clean tests run

all: $(BIN)

$(BIN): $(OBJS)
	$(CC) $^ -o $@ -lm

%.o: %.c
	$(CC) $(CFLAGS) -c $< -o $@

tests: $(TEST_BINS)
	@for t in $(TEST_BINS); do echo "==> $$t" && ./$$t || exit 1; done

tests/test_%: tests/test_%.c src-cpu/kernels.o
	$(CC) $(CFLAGS) $^ -o $@ -lm

run: $(BIN)
	./$(BIN) --prompt "Hello, who are you?" --max-tokens 16

clean:
	rm -f src-cpu/*.o tests/*.o $(BIN) $(TEST_BINS)
