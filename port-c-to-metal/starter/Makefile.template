# Makefile.template — C + Metal build for the naive Apple-GPU port.
#
# Replace <BIN> with your binary name, e.g., `gptoss`.

CC      ?= clang
OBJC    ?= clang
CFLAGS    := -std=c99 -O2 -Wall -Wextra -Wno-unused-parameter -Icsrc
OBJCFLAGS := -std=c99 -O2 -Wall -Wextra -Wno-unused-parameter -fobjc-arc -ObjC -Icsrc
LDFLAGS   := -framework Foundation -framework Metal -framework MetalKit

BIN     := <BIN>

C_SRCS  := csrc/main.c \
           csrc/kernel_concat.c \
           csrc/safetensors.c \
           csrc/tokenizer.c \
           csrc/<chattmpl>.c
M_SRCS  := csrc/metal_shim.m
OBJS    := $(C_SRCS:.c=.o) $(M_SRCS:.m=.o)

.PHONY: all clean run

all: $(BIN)

$(BIN): $(OBJS)
	$(CC) $^ -o $@ $(LDFLAGS)

csrc/%.o: csrc/%.c
	$(CC) $(CFLAGS) -c $< -o $@

csrc/%.o: csrc/%.m
	$(OBJC) $(OBJCFLAGS) -c $< -o $@

run: $(BIN)
	./$(BIN) --prompt "Hello, who are you?" --max-tokens 16

clean:
	rm -f csrc/*.o $(BIN)
